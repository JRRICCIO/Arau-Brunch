---
pagination:
  data: languages
  size: 1
  alias: lng
permalink: "/{{ lng.dir }}"
pageKey: "home"
---
{%- set arauWord %}{% include "arau-word.njk" %}{% endset -%}
<!DOCTYPE html>
<html lang="{{ lng.htmlLang }}" class="no-js">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#e6dcc2" />

  <title>ARAU · Brunch & Café de especialidad — Barcelona</title>
  <meta name="description" content="Sabores argentinos, espíritu australiano, corazón barcelonés. Brunch de inspiración argentino-australiana y café de especialidad en el Eixample, Barcelona." />

  <link rel="canonical" href="{{ site.baseUrl }}/{{ lng.dir }}" />
{% include "seo-hreflang.njk" %}

  <meta property="og:type" content="restaurant" />
  <meta property="og:site_name" content="ARAU" />
  <meta property="og:title" content="ARAU · Brunch & Café de especialidad" />
  <meta property="og:description" content="Sabores argentinos, espíritu australiano, corazón barcelonés. Brunch argentino-australiano y café de especialidad en el Eixample, Barcelona." />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:url" content="{{ site.baseUrl }}/{{ lng.dir }}" />
  <meta property="og:image" content="https://arau-brunch.netlify.app/img/facade.jpg" />
  <meta property="og:image:alt" content="Fachada de ARAU con su arco de terracota en Provença 322, Barcelona" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="ARAU · Brunch & Café de especialidad" />
  <meta name="twitter:description" content="Brunch argentino-australiano y café de especialidad en el Eixample, Barcelona." />
  <meta name="twitter:image" content="https://arau-brunch.netlify.app/img/facade.jpg" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Restaurant",
    "name": "ARAU — Brunch & Café de especialidad",
    "description": "Brunch de inspiración argentino-australiana y café de especialidad en el Eixample, Barcelona.",
    "image": "https://arau-brunch.netlify.app/img/facade.jpg",
    "url": "{{ site.baseUrl }}/{{ lng.dir }}",
    "servesCuisine": ["Brunch", "Argentina", "Australiana", "Café de especialidad"],
    "priceRange": "€€",
    "acceptsReservations": "True",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Carrer de Provença, 322",
      "addressLocality": "Barcelona",
      "postalCode": "08037",
      "addressRegion": "Cataluña",
      "addressCountry": "ES"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 41.3968763, "longitude": 2.1644798 },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Wednesday", "Thursday", "Friday"], "opens": "09:00", "closes": "16:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday", "Sunday"], "opens": "09:30", "closes": "17:00" }
    ],
    "sameAs": ["https://instagram.com/araubrunch", "https://tiktok.com/@araubrunch"]
  }
  </script>

  <!-- Favicon: logo ARAU (tacita con anteojos) -->
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 104'%3E%3Crect width='100' height='104' rx='20' fill='%23e6dcc2'/%3E%3Cg fill='none' stroke='%23af452e' stroke-width='4' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpath d='M43 20c-3-3-3-6 0-9'/%3E%3Cpath d='M50 18c-3-3-3-6 0-9'/%3E%3Cpath d='M57 20c-3-3-3-6 0-9'/%3E%3Cellipse cx='50' cy='30' rx='17' ry='4.6'/%3E%3Cpath d='M33 30c0 16 2 28 4 37a4 4 0 0 0 4 3h18a4 4 0 0 0 4-3c2-9 4-21 4-37'/%3E%3Cpath d='M35.5 39c6 2 23 2 29 0'/%3E%3Cpath d='M44 60c4 3.5 8 3.5 12 0'/%3E%3Cpath d='M33 47c-5 1-10-1-13-6'/%3E%3Cpath d='M20 41l-3-19'/%3E%3Cpath d='M67 47c5 1 10-1 13-6'/%3E%3Cpath d='M80 41l3-19'/%3E%3Cpath d='M80.4 26l-.5-5M83 26l.4-5'/%3E%3Cpath d='M44 70l-2 13M42 83l-6 2'/%3E%3Cpath d='M56 70l2 13M58 83l6 2'/%3E%3C/g%3E%3Cpath d='M17 22l-2.6 4.5 5.4 0z' fill='%23af452e'/%3E%3Cg fill='%23af452e'%3E%3Crect x='37.5' y='45' width='10.5' height='7.4' rx='3.4'/%3E%3Crect x='52' y='45' width='10.5' height='7.4' rx='3.4'/%3E%3Crect x='47' y='47' width='6' height='2.2' rx='1'/%3E%3C/g%3E%3C/svg%3E" />

  <!-- Fuentes self-hosted (sin round-trip a Google) -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/lato-900.woff2" crossorigin />
  <link rel="preload" as="font" type="font/woff2" href="/fonts/lato-400.woff2" crossorigin />
  <!-- Precarga del hero (LCP) -->
  <link rel="preload" as="image" href="{{ site.hero.image | asset }}" type="image/webp" fetchpriority="high" />

  <link rel="stylesheet" href="/styles.css" />
  <script>document.documentElement.classList.remove('no-js');document.documentElement.classList.add('js');</script>
</head>
<body>
  <a class="skip-link" href="#contenido">{{ ui.a11y.skipToContent }}</a>
  <div class="scroll-progress" aria-hidden="true"></div>

  <!-- ===================== HEADER ===================== -->
  <header class="site-header site-header--overlay" id="top">
    <div class="container header__inner">
      <a class="brand" href="#top" aria-label="{{ ui.a11y.brandHomeLabel }}">
        <span class="brand__mark" aria-hidden="true">
          {% include "logo-mark.njk" %}
        </span>
        <span class="brand__word" translate="no">{% include "arau-word.njk" %}</span>
      </a>

      <nav class="nav" aria-label="{{ ui.a11y.navLabel }}">
        <ul class="nav__list" id="primary-nav">
          <li><a href="carta.html">{{ ui.nav.carta }}</a></li>
          <li><a href="#nosotros">{{ ui.nav.nosotros }}</a></li>
          <li><a href="#cafe">{{ ui.nav.cafe }}</a></li>
          <li><a href="#eventos">{{ ui.nav.eventos }}</a></li>
          <li><a href="#visitanos">{{ ui.nav.visitanos }}</a></li>
        </ul>
      </nav>

      <div class="header__actions">
        {% include "lang-switcher.njk" %}
        <a class="btn btn--terra" href="#reservar">{{ ui.cta.reservar }}</a>
        <button class="nav-toggle" type="button" aria-label="{{ ui.a11y.openMenu }}" aria-expanded="false" aria-controls="primary-nav">
          <span class="nav-toggle__bar" aria-hidden="true"></span>
          <span class="nav-toggle__bar" aria-hidden="true"></span>
          <span class="nav-toggle__bar" aria-hidden="true"></span>
        </button>
      </div>
    </div>
  </header>

  <main id="contenido">

    <!-- ===================== HERO ===================== -->
    <section class="hero" aria-labelledby="hero-title">
      <img class="hero__bg" src="{{ site.hero.image | asset }}" alt="{{ site.hero.imageAlt }}" width="720" height="960" fetchpriority="high" />
      <span class="hero__scrim" aria-hidden="true"></span>

      <div class="container hero__inner">
        <div class="hero__copy">
          <p class="eyebrow">
            <span class="eyebrow__dot" aria-hidden="true"></span>
            {{ ui.hero.eyebrow }}
          </p>
          <span id="open-status" class="open-badge" aria-live="polite"></span>

          <h1 class="hero__title" id="hero-title">
            {{ site.hero.titleStart }} <span class="hero__title-accent swap" id="hero-swap" aria-label="{{ site.hero.titleAccent }}">{%- for w in (site.hero.accentSwap or [site.hero.titleAccent]) %}<span class="swap__w{% if loop.first %} is-on{% endif %}" aria-hidden="true">{{ w }}</span>{%- endfor %}</span>
          </h1>

          <p class="hero__lead">{{ site.hero.lead }}</p>

          <div class="hero__cta">
            <a class="btn btn--terra btn--lg" href="carta.html">
              {{ ui.cta.verLaCarta }}
              <svg class="btn__arrow" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a class="btn btn--ghost btn--lg btn--on-photo" href="#reservar">{{ ui.cta.reservarMesa }}</a>
          </div>

          <ul class="hero__trust" aria-label="{{ ui.a11y.heroTrustLabel }}">
            <li>
              <span class="hero__trust-num">4.8<span class="hero__trust-star" aria-hidden="true">★</span></span>
              <span class="hero__trust-label">{{ ui.hero.trust.reviews }}</span>
            </li>
            <li aria-hidden="true" class="hero__trust-sep"></li>
            <li>
              <span class="hero__trust-num">100%</span>
              <span class="hero__trust-label">{{ ui.hero.trust.local }}</span>
            </li>
            <li aria-hidden="true" class="hero__trust-sep"></li>
            <li>
              <span class="hero__trust-num">1500+</span>
              <span class="hero__trust-label">{{ ui.hero.trust.coffee }}</span>
            </li>
          </ul>
        </div>
      </div>

      <a class="hero__cue" href="#nosotros" aria-label="{{ ui.a11y.heroCue }}">
        <span class="hero__cue-mark" aria-hidden="true">
          {% include "logo-mark.njk" %}
        </span>
        <span class="hero__cue-chevron" aria-hidden="true"></span>
      </a>
    </section>

    <!-- ===================== MARQUEE ===================== -->
    <div class="marquee" aria-hidden="true">
      <div class="marquee__track">
        <span>Aussie soul</span><span class="marquee__sep">✶</span>
        <span>Argentinian heart</span><span class="marquee__sep">✶</span>
        <span>Dulce de leche</span><span class="marquee__sep">✶</span>
        <span>Specialty coffee</span><span class="marquee__sep">✶</span>
        <span>Pan de masa madre</span><span class="marquee__sep">✶</span>
        <span>Aussie soul</span><span class="marquee__sep">✶</span>
        <span>Argentinian heart</span><span class="marquee__sep">✶</span>
        <span>Dulce de leche</span><span class="marquee__sep">✶</span>
        <span>Specialty coffee</span><span class="marquee__sep">✶</span>
        <span>Pan de masa madre</span><span class="marquee__sep">✶</span>
      </div>
    </div>

    <!-- ===================== HISTORIA ===================== -->
    <section class="historia section" id="nosotros" aria-labelledby="hist-title">
      <div class="container historia__grid">
        <figure class="historia__frame reveal">
          <button type="button" class="historia__photo thumb" data-gallery="lugar"
                  data-full="/img/fachada.webp" data-caption="La fachada de ARAU en Carrer de Provença 322, Eixample">
            <img src="/img/fachada.webp" alt="{{ ui.historia.imgAlt }}" width="720" height="900" loading="lazy" decoding="async" />
          </button>
          <figcaption class="historia__cap">{{ ui.historia.cap }}</figcaption>
        </figure>

        <div class="historia__body reveal">
          <p class="section-eyebrow">{{ ui.historia.eyebrow }}</p>
          <h2 class="section-title" id="hist-title">
            {{ ui.historia.title | safe }}
          </h2>
          <p>
            {{ ui.historia.p1 | replace("[[ARAU]]", arauWord) | safe }}
          </p>
          <p>
            {{ ui.historia.p2 | safe }}
          </p>
          <p>
            {{ ui.historia.p3 }}
          </p>
          <p>
            {{ ui.historia.p4 | replace("[[ARAU]]", arauWord) | safe }}
          </p>
          <p class="historia__sign">{{ ui.historia.sign | replace("[[ARAU]]", arauWord) | safe }}</p>
        </div>
      </div>

      <div class="container stats reveal" aria-label="{{ ui.a11y.statsLabel }}">
        <div class="stat">
          <span class="stat__num">100%</span>
          <span class="stat__label">{{ ui.stats.local.label }}</span>
        </div>
        <div class="stat">
          <span class="stat__num">1500+</span>
          <span class="stat__label">{{ ui.stats.coffee.label }}</span>
        </div>
        <div class="stat">
          <span class="stat__num">4.8<span class="stat__star" aria-hidden="true">★</span></span>
          <span class="stat__label">{{ ui.stats.reviews.label }}</span>
        </div>
      </div>

      <div class="container heart-close reveal">
        <img class="heart-close__img" src="/img/manos-corazon.webp" alt="{{ ui.historia.heartImgAlt }}" width="240" height="100" loading="lazy" decoding="async" />
        <p class="heart-close__line">{{ ui.historia.heartLine }}</p>
      </div>
    </section>

    <!-- ===================== GALERÍA (carrusel) ===================== -->
    <section class="galeria" aria-labelledby="galeria-label">
      <h2 class="galeria__overline" id="galeria-label">{{ galeria.overline }}</h2>
      <div class="galeria__carousel" role="group" aria-roledescription="{{ ui.carousel.region }}" aria-labelledby="galeria-label">
        <button type="button" class="galeria__arrow galeria__arrow--prev" data-car="prev" aria-label="{{ ui.carousel.prev }}">
          <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true"><path d="M15 4l-8 8 8 8" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="galeria__track" data-car="track">
          {%- for item in galeria.items %}
          <button type="button" class="galeria__item thumb" data-gallery="galeria"
                  data-full="{{ item.src | asset }}" data-caption="{{ item.caption }}">
            <img src="{{ item.src | asset }}" alt="{{ item.alt }}" width="760" height="520" loading="lazy" decoding="async" />
          </button>
          {%- endfor %}
        </div>
        <button type="button" class="galeria__arrow galeria__arrow--next" data-car="next" aria-label="{{ ui.carousel.next }}">
          <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true"><path d="M9 4l8 8-8 8" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
      <div class="galeria__dots" data-car="dots" role="group" aria-label="{{ galeria.overline }}">
        {%- for item in galeria.items %}
        <button type="button" class="galeria__dot{% if loop.first %} is-active{% endif %}" data-car-go="{{ loop.index0 }}" aria-label="{{ ui.carousel.goto }} {{ loop.index }}"{% if loop.first %} aria-current="true"{% endif %}></button>
        {%- endfor %}
      </div>
    </section>

    <!-- ===================== CARTA ===================== -->
    <section class="carta section" id="carta" aria-labelledby="carta-title">
      <div class="container">
        <div class="carta__head reveal">
          <p class="section-eyebrow">{{ ui.carta.home.eyebrow }}</p>
          <h2 class="section-title" id="carta-title">
            {{ ui.carta.home.title | safe }}
          </h2>
          <p class="carta__sub">{{ ui.carta.home.sub }}</p>
        </div>

        <div class="dishes">
          <a class="dish dish--photo dish--link reveal" href="carta.html#brunch">
            <div class="dish__photo" aria-hidden="true">
              <img src="/img/big-arau.webp" alt="" width="600" height="380" loading="lazy" decoding="async" />
            </div>
            <div class="dish__text">
              <h3 class="dish__name">{{ ui.carta.home.dish1.name }}</h3>
              <p class="dish__desc">{{ ui.carta.home.dish1.desc }}</p>
              <span class="dish__tag">{{ ui.carta.home.dish1.tag }}</span>
            </div>
          </a>

          <a class="dish dish--photo dish--link reveal" href="carta.html#brunch">
            <div class="dish__photo" aria-hidden="true">
              <img src="/img/eggs-benedict-v2.webp" alt="" width="600" height="380" loading="lazy" decoding="async" />
            </div>
            <div class="dish__text">
              <h3 class="dish__name">{{ ui.carta.home.dish2.name }}</h3>
              <p class="dish__desc">{{ ui.carta.home.dish2.desc }}</p>
              <span class="dish__tag">{{ ui.carta.home.dish2.tag }}</span>
            </div>
          </a>

          <a class="dish dish--photo dish--link reveal" href="carta.html#almuerzos">
            <div class="dish__photo" aria-hidden="true">
              <img src="/img/tru-mila-v2.webp" alt="" width="600" height="380" loading="lazy" decoding="async" />
            </div>
            <div class="dish__text">
              <h3 class="dish__name">{{ ui.carta.home.dish3.name }}</h3>
              <p class="dish__desc">{{ ui.carta.home.dish3.desc }}</p>
              <span class="dish__tag">{{ ui.carta.home.dish3.tag }}</span>
            </div>
          </a>

          <a class="dish dish--photo dish--link reveal" href="carta.html#postres">
            <div class="dish__photo" aria-hidden="true">
              <img src="/img/flan-v2.webp" alt="" width="600" height="380" loading="lazy" decoding="async" />
            </div>
            <div class="dish__text">
              <h3 class="dish__name">{{ ui.carta.home.dish4.name }}</h3>
              <p class="dish__desc">{{ ui.carta.home.dish4.desc }}</p>
              <span class="dish__tag">{{ ui.carta.home.dish4.tag }}</span>
            </div>
          </a>
        </div>

        <div class="carta__cta reveal">
          <a class="btn btn--terra btn--lg" href="carta.html">
            {{ ui.carta.home.ctaFull }}
            <svg class="btn__arrow" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a class="btn btn--ghost btn--lg" href="#reservar">{{ ui.cta.reservaTuMesa }}</a>
          <p class="carta__note">{{ ui.carta.home.note }}</p>
        </div>
      </div>
    </section>

    <!-- ===================== CAFÉ ===================== -->
    <section class="cafe section" id="cafe" aria-labelledby="cafe-title">
      <div class="container cafe__grid">
        <div class="cafe__art reveal" aria-hidden="true">
          <div class="cafe__photo">
            <img src="/img/cafe-v2.webp" alt="{{ ui.cafe.imgAlt }}" width="600" height="800" loading="lazy" decoding="async" />
          </div>
        </div>
        <div class="cafe__copy reveal">
          <p class="section-eyebrow section-eyebrow--cream">{{ ui.cafe.eyebrow }}</p>
          <h2 class="section-title section-title--cream" id="cafe-title">
            {{ ui.cafe.title | safe }}
          </h2>
          <p class="cafe__lead">
            {{ ui.cafe.lead | safe }}
          </p>
          <ul class="cafe__chips">
            <li>{{ ui.cafe.chip1 }}</li>
            <li>{{ ui.cafe.chip2 }}</li>
            <li>{{ ui.cafe.chip3 }}</li>
            <li>{{ ui.cafe.chip4 }}</li>
            <li>{{ ui.cafe.chip5 }}</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ===================== EVENTOS ===================== -->
    <section class="eventos section" id="eventos" aria-labelledby="eventos-title">
      <div class="container">
        <div class="eventos__head reveal">
          <p class="section-eyebrow">{{ ui.eventos.eyebrow }}</p>
          <h2 class="section-title" id="eventos-title">{{ ui.eventos.title | replace("[[ARAU]]", arauWord) | safe }}</h2>
          <p class="carta__sub">{{ ui.eventos.sub | safe }}</p>
        </div>

        {% include "eventos.njk" %}

        <div class="loyalty reveal">
          <span class="loyalty__badge" aria-hidden="true">★</span>
          <p class="loyalty__text">
            {{ ui.loyalty.text | safe }}
          </p>
        </div>
      </div>
    </section>

    <!-- ===================== EXPERIENCIA / RESEÑAS ===================== -->
    <section class="experiencia section" id="experiencia" aria-labelledby="exp-title">
      <div class="container">
        <div class="experiencia__head reveal">
          <p class="section-eyebrow">{{ ui.experiencia.eyebrow }}</p>
          <h2 class="section-title" id="exp-title">{{ ui.experiencia.title | safe }}</h2>
          <p class="carta__sub">{{ ui.experiencia.sub | replace("[[ARAU]]", arauWord) | safe }}</p>
        </div>

        <div class="reviews-summary reveal">
          <p class="reviews-summary__score">4,8 <span class="reviews-summary__stars" aria-hidden="true">★★★★★</span></p>
          <p class="reviews-summary__text">{{ ui.experiencia.reviewsText | replace("[[ARAU]]", arauWord) | safe }}</p>
          <a class="btn btn--terra btn--lg" href="https://www.google.com/maps/search/?api=1&amp;query=ARAU%20brunch%20Carrer%20de%20Proven%C3%A7a%20322%20Barcelona" target="_blank" rel="noopener noreferrer">
            {{ ui.experiencia.readReviews }}
            <svg class="btn__arrow" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ===================== VISITANOS ===================== -->
    <section class="visitanos section" id="visitanos" aria-labelledby="visit-title">
      <div class="container visitanos__grid">
        <div class="visitanos__info reveal">
          <p class="section-eyebrow section-eyebrow--cream">{{ ui.visitanos.eyebrow }}</p>
          <h2 class="section-title section-title--cream" id="visit-title">{{ ui.visitanos.title | safe }}</h2>

          <dl class="info">
            <div class="info__row">
              <dt>{{ ui.visitanos.dondeLabel }}</dt>
              <dd>
                {{ site.contacto.direccion }}<br />
                {{ site.contacto.ciudad }}
              </dd>
            </div>
            <div class="info__row">
              <dt>{{ ui.visitanos.horarioLabel }}</dt>
              <dd>
                <ul class="hours">
                  {%- for h in site.horarios %}
                  <li{% if h.cerrado %} class="hours--closed"{% endif %}><span>{{ h.dia }}</span><span>{% if h.cerrado %}{{ ui.visitanos.cerrado }}{% else %}{{ h.apertura }} – {{ h.cierre }}{% endif %}</span></li>
                  {%- endfor %}
                </ul>
              </dd>
            </div>
            <div class="info__row">
              <dt>{{ ui.visitanos.contactoLabel }}</dt>
              <dd>
                <a class="info__link" href="tel:{{ site.contacto.telefonoLink }}">{{ site.contacto.telefono }}</a><br />
                <a class="info__link" href="mailto:{{ site.contacto.email }}">{{ site.contacto.email }}</a>
              </dd>
            </div>
          </dl>

          <div class="socials" aria-label="{{ ui.a11y.socialsLabel }}">
            <a class="social" href="https://instagram.com/araubrunch" target="_blank" rel="noopener noreferrer" aria-label="{{ ui.a11y.instagramLabel }}">
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="17.5" cy="6.5" r="1.4" fill="currentColor"/></svg>
              <span>@araubrunch</span>
            </a>
            <a class="social" href="https://tiktok.com/@araubrunch" target="_blank" rel="noopener noreferrer" aria-label="{{ ui.a11y.tiktokLabel }}">
              <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M14 4c.5 2.7 2.3 4.4 5 4.6v3c-1.8 0-3.5-.6-5-1.6V16a5.5 5.5 0 1 1-5.5-5.5c.3 0 .6 0 .9.1v3.1a2.5 2.5 0 1 0 1.6 2.3V4z" fill="currentColor"/></svg>
              <span>@araubrunch</span>
            </a>
          </div>
        </div>

        <div class="visitanos__map reveal">
          <iframe title="{{ ui.visitanos.mapTitle }}"
                  src="https://maps.google.com/maps?q=Carrer%20de%20Proven%C3%A7a%20322%20Barcelona&t=&z=15&ie=UTF8&iwloc=&output=embed"
                  width="100%" height="460" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          <p class="map-embed__alt">
            <a class="inline-link" href="https://maps.google.com/maps?q=Carrer+de+Proven%C3%A7a+322+Barcelona" target="_blank" rel="noopener noreferrer">{{ ui.visitanos.openInMaps }}</a>
          </p>
        </div>
      </div>
    </section>

    <!-- ===================== RESERVAR ===================== -->
    <section class="reservar section" id="reservar" aria-labelledby="reservar-title">
      <div class="container reservar__inner">
        <div class="reservar__intro reveal">
          <p class="section-eyebrow">{{ ui.reservar.eyebrow }}</p>
          <h2 class="section-title" id="reservar-title">{{ ui.reservar.title | safe }}</h2>
          <p class="reservar__lead">
            {{ ui.reservar.lead }}
          </p>
          <a class="reservar__wa" href="https://wa.me/{{ site.contacto.whatsapp }}" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.6 4.7-1.2A10 10 0 1 0 12 2zm0 2a8 8 0 1 1-4.2 14.8l-.3-.2-2.5.6.7-2.4-.2-.3A8 8 0 0 1 12 4zm4.5 9.6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1l-.7.9c-.1.1-.3.2-.5 0a6.5 6.5 0 0 1-3.2-2.8c-.2-.3.2-.4.4-.8.1-.1 0-.3 0-.4l-.7-1.7c-.2-.4-.4-.4-.5-.4h-.5c-.2 0-.4 0-.6.3-.2.3-.8.8-.8 1.9s.8 2.2 1 2.4c.1.1 1.6 2.5 4 3.5 1.5.6 2 .7 2.7.6.4-.1 1.4-.6 1.6-1.1.2-.6.2-1 .1-1.1z" fill="currentColor"/></svg>
            {{ ui.reservar.waButton }}
          </a>
        </div>

        <form class="reserva-form reveal" id="reserva-form" name="reserva" method="POST"
              data-netlify="true" netlify-honeypot="bot-field" action="/?reserva=ok#reservar" novalidate>
          <input type="hidden" name="form-name" value="reserva" />
          <p class="hp-field" hidden aria-hidden="true">
            <label>{{ ui.form.honeypotLabel }} <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </p>
          <div class="field">
            <label for="rf-nombre">{{ ui.form.nombreLabel }}</label>
            <input id="rf-nombre" name="nombre" type="text" autocomplete="name" placeholder="{{ ui.form.nombrePlaceholder }}" required />
          </div>

          <div class="field-row">
            <div class="field">
              <label for="rf-fecha">{{ ui.form.fechaLabel }}</label>
              <input id="rf-fecha" name="fecha" type="date" required />
            </div>
            <div class="field">
              <label for="rf-hora">{{ ui.form.horaLabel }}</label>
              <input id="rf-hora" name="hora" type="time" required />
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="rf-personas">{{ ui.form.personasLabel }}</label>
              <input id="rf-personas" name="personas" type="number" inputmode="numeric" min="1" max="8" step="1" value="2" required />
            </div>
            <div class="field">
              <label for="rf-tel">{{ ui.form.telefonoLabel }}</label>
              <input id="rf-tel" name="telefono" type="tel" autocomplete="tel" inputmode="tel" placeholder="{{ ui.form.telefonoPlaceholder }}" required />
            </div>
          </div>

          <div class="field">
            <label for="rf-email">{{ ui.form.emailLabel }}</label>
            <input id="rf-email" name="email" type="email" autocomplete="email" spellcheck="false" placeholder="{{ ui.form.emailPlaceholder }}" required />
          </div>

          <div class="field">
            <label for="rf-notas">{{ ui.form.notasLabel | safe }}</label>
            <textarea id="rf-notas" name="notas" rows="3" placeholder="{{ ui.form.notasPlaceholder }}"></textarea>
          </div>

          <button class="btn btn--terra btn--lg btn--block" type="submit">{{ ui.form.submit }}</button>
          <p class="reserva-form__hint" id="rf-hint" aria-live="polite">
            {{ ui.form.hint }}
          </p>
        </form>
      </div>
    </section>
  </main>

  <!-- ===================== FOOTER ===================== -->
  <footer class="site-footer">
    <div class="container footer__grid">
      <div class="footer__brand">
        <a class="brand brand--footer" href="#top" aria-label="{{ ui.a11y.brandHomeLabel }}">
          <span class="brand__mark" aria-hidden="true">
            {% include "logo-mark.njk" %}
          </span>
          <span class="brand__word" translate="no">{% include "arau-word.njk" %}</span>
        </a>
        <p class="footer__tag">{{ ui.footer.tag | safe }}</p>
      </div>

      <nav class="footer__nav" aria-label="{{ ui.a11y.footerNavLabel }}">
        <a href="#nosotros">{{ ui.footer.nav.nosotros }}</a>
        <a href="#carta">{{ ui.footer.nav.laCarta }}</a>
        <a href="#cafe">{{ ui.footer.nav.cafe }}</a>
        <a href="#eventos">{{ ui.footer.nav.eventos }}</a>
        <a href="#reservar">{{ ui.footer.nav.reservar }}</a>
      </nav>

      <div class="footer__contact">
        <p>{{ site.contacto.direccion }} · Barcelona</p>
        <p><a href="tel:{{ site.contacto.telefonoLink }}">{{ site.contacto.telefono }}</a> · <a href="mailto:{{ site.contacto.email }}">{{ site.contacto.email }}</a></p>
        <p class="footer__social-row">
          <a href="https://instagram.com/araubrunch" target="_blank" rel="noopener noreferrer">Instagram</a> ·
          <a href="https://tiktok.com/@araubrunch" target="_blank" rel="noopener noreferrer">TikTok</a>
        </p>
      </div>
    </div>

    <div class="container footer__bottom">
      <p>{{ ui.footer.copyright | replace("[[YEAR]]", buildYear) | replace("[[ARAU]]", arauWord) | safe }}</p>
      <p class="footer__credit">{{ ui.footer.credit | safe }}</p>
    </div>
  </footer>

  <!-- Botón WhatsApp flotante -->
  <a class="wa-float" href="https://wa.me/{{ site.contacto.whatsapp }}" target="_blank" rel="noopener noreferrer" aria-label="{{ ui.a11y.waFloatLabel }}">
    <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.6 4.7-1.2A10 10 0 1 0 12 2zm0 2a8 8 0 1 1-4.2 14.8l-.3-.2-2.5.6.7-2.4-.2-.3A8 8 0 0 1 12 4zm4.5 9.6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1l-.7.9c-.1.1-.3.2-.5 0a6.5 6.5 0 0 1-3.2-2.8c-.2-.3.2-.4.4-.8.1-.1 0-.3 0-.4l-.7-1.7c-.2-.4-.4-.4-.5-.4h-.5c-.2 0-.4 0-.6.3-.2.3-.8.8-.8 1.9s.8 2.2 1 2.4c.1.1 1.6 2.5 4 3.5 1.5.6 2 .7 2.7.6.4-.1 1.4-.6 1.6-1.1.2-.6.2-1 .1-1.1z" fill="currentColor"/></svg>
    <span class="wa-float__label">{{ ui.waFloat.label }}</span>
  </a>

  <!-- Barra de acción fija (móvil) -->
  <div class="cta-bar" id="cta-bar" aria-hidden="true">
    <a class="cta-bar__btn cta-bar__btn--wa" href="https://wa.me/{{ site.contacto.whatsapp }}" target="_blank" rel="noopener noreferrer" aria-label="{{ ui.a11y.ctaBarWa }}">
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.6 4.7-1.2A10 10 0 1 0 12 2zm0 2a8 8 0 1 1-4.2 14.8l-.3-.2-2.5.6.7-2.4-.2-.3A8 8 0 0 1 12 4zm4.5 9.6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1l-.7.9c-.1.1-.3.2-.5 0a6.5 6.5 0 0 1-3.2-2.8c-.2-.3.2-.4.4-.8.1-.1 0-.3 0-.4l-.7-1.7c-.2-.4-.4-.4-.5-.4h-.5c-.2 0-.4 0-.6.3-.2.3-.8.8-.8 1.9s.8 2.2 1 2.4c.1.1 1.6 2.5 4 3.5 1.5.6 2 .7 2.7.6.4-.1 1.4-.6 1.6-1.1.2-.6.2-1 .1-1.1z" fill="currentColor"/></svg>
    </a>
    <a class="cta-bar__btn cta-bar__btn--primary" href="#reservar">{{ ui.ctaBar.reservarMesa }}</a>
  </div>

  <!-- Lightbox reutilizable (galería + platos + eventos) -->
  <dialog class="lightbox" id="lightbox" aria-label="{{ ui.a11y.lightboxLabel }}">
    <button type="button" class="lightbox__close" data-lb="close" aria-label="{{ ui.a11y.lightboxClose }}">
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
    </button>
    <button type="button" class="lightbox__nav lightbox__prev" data-lb="prev" aria-label="{{ ui.a11y.prevPhoto }}">
      <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true"><path d="M15 5l-7 7 7 7" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <figure class="lightbox__fig">
      <img class="lightbox__img" id="lightbox-img" alt="" />
      <figcaption class="lightbox__cap" id="lightbox-cap"></figcaption>
    </figure>
    <button type="button" class="lightbox__nav lightbox__next" data-lb="next" aria-label="{{ ui.a11y.lightboxNext }}">
      <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true"><path d="M9 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <p class="lightbox__count" id="lightbox-count" aria-live="polite"></p>
  </dialog>

  <!-- Diálogo de inscripción a eventos (Netlify Forms) -->
  <dialog class="inscripcion" id="inscripcion-dialog" aria-labelledby="insc-title">
    <button type="button" class="inscripcion__close" data-insc="close" aria-label="{{ ui.inscripcion.cerrar }}">
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
    </button>
    <form class="inscripcion__form" id="inscripcion-form" name="inscripcion-evento" method="POST"
          data-netlify="true" netlify-honeypot="bot-field"
          data-msg-ok="{{ ui.inscripcion.success }}" data-msg-err="{{ ui.inscripcion.errorMsg }}">
      <input type="hidden" name="form-name" value="inscripcion-evento" />
      <p class="hp-field" hidden aria-hidden="true">
        <label>{{ ui.form.honeypotLabel }} <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
      </p>
      <input type="hidden" name="evento" id="insc-evento" />
      <input type="hidden" name="evento_nombre" id="insc-evento-nombre" />

      <h2 class="inscripcion__title" id="insc-title">{{ ui.inscripcion.title }} <span id="insc-evento-label"></span></h2>

      <div class="field">
        <label for="insc-nombre">{{ ui.inscripcion.nombreLabel }}</label>
        <input id="insc-nombre" name="nombre" type="text" autocomplete="name" placeholder="{{ ui.form.nombrePlaceholder }}" required />
      </div>

      <div class="field">
        <label for="insc-email">{{ ui.inscripcion.emailLabel }}</label>
        <input id="insc-email" name="email" type="email" autocomplete="email" spellcheck="false" placeholder="{{ ui.form.emailPlaceholder }}" required />
      </div>

      <div class="field-row">
        <div class="field">
          <label for="insc-tel">{{ ui.inscripcion.telefonoLabel }}</label>
          <input id="insc-tel" name="telefono" type="tel" autocomplete="tel" inputmode="tel" placeholder="{{ ui.form.telefonoPlaceholder }}" required />
        </div>
        <div class="field">
          <label for="insc-personas">{{ ui.inscripcion.personasLabel }}</label>
          <input id="insc-personas" name="personas" type="number" inputmode="numeric" min="1" max="20" step="1" value="2" required />
        </div>
      </div>

      <button class="btn btn--terra btn--lg btn--block" type="submit">{{ ui.inscripcion.submit }}</button>
      <p class="inscripcion__hint" id="insc-hint" aria-live="polite"></p>
    </form>
  </dialog>

  <script src="/script.js" defer></script>
  {% include "jmrr-credit.njk" %}
</body>
</html>
