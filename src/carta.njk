{%- set arauWord %}{% include "arau-word.njk" %}{% endset -%}
<!DOCTYPE html>
<html lang="{{ lng.htmlLang }}" class="no-js">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#e6dcc2" />

  <title>Carta · ARAU — Brunch &amp; Café de especialidad, Barcelona</title>
  <meta name="description" content="La carta completa de ARAU: huevos en su punto, milanesas, dulces caseros y café de especialidad en el Eixample, Barcelona. Sabores argentinos, espíritu australiano." />

  <link rel="canonical" href="{{ site.baseUrl }}/{{ lng.dir }}carta.html" />
{% include "seo-hreflang.njk" %}

  <meta property="og:type" content="restaurant.menu" />
  <meta property="og:site_name" content="ARAU" />
  <meta property="og:title" content="Carta · ARAU — Brunch & Café de especialidad" />
  <meta property="og:description" content="La carta completa: huevos, milanesas, dulces caseros y café de especialidad en Barcelona. Sabores argentinos, espíritu australiano." />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:url" content="{{ site.baseUrl }}/{{ lng.dir }}carta.html" />
  <meta property="og:image" content="https://araubrunch.es/img/spread.jpg" />
  <meta property="og:image:alt" content="Mesa de ARAU con tostada de palta, eggs benedict y café de especialidad" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://araubrunch.es/img/spread.jpg" />

  <!-- Favicon: logo ARAU (tacita con anteojos) -->
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 104'%3E%3Crect width='100' height='104' rx='20' fill='%23e6dcc2'/%3E%3Cg fill='none' stroke='%23af452e' stroke-width='4' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpath d='M43 20c-3-3-3-6 0-9'/%3E%3Cpath d='M50 18c-3-3-3-6 0-9'/%3E%3Cpath d='M57 20c-3-3-3-6 0-9'/%3E%3Cellipse cx='50' cy='30' rx='17' ry='4.6'/%3E%3Cpath d='M33 30c0 16 2 28 4 37a4 4 0 0 0 4 3h18a4 4 0 0 0 4-3c2-9 4-21 4-37'/%3E%3Cpath d='M35.5 39c6 2 23 2 29 0'/%3E%3Cpath d='M44 60c4 3.5 8 3.5 12 0'/%3E%3Cpath d='M33 47c-5 1-10-1-13-6'/%3E%3Cpath d='M20 41l-3-19'/%3E%3Cpath d='M67 47c5 1 10-1 13-6'/%3E%3Cpath d='M80 41l3-19'/%3E%3Cpath d='M80.4 26l-.5-5M83 26l.4-5'/%3E%3Cpath d='M44 70l-2 13M42 83l-6 2'/%3E%3Cpath d='M56 70l2 13M58 83l6 2'/%3E%3C/g%3E%3Cpath d='M17 22l-2.6 4.5 5.4 0z' fill='%23af452e'/%3E%3Cg fill='%23af452e'%3E%3Crect x='37.5' y='45' width='10.5' height='7.4' rx='3.4'/%3E%3Crect x='52' y='45' width='10.5' height='7.4' rx='3.4'/%3E%3Crect x='47' y='47' width='6' height='2.2' rx='1'/%3E%3C/g%3E%3C/svg%3E" />

  <!-- Fuentes self-hosted (sin round-trip a Google) -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/lato-900.woff2" crossorigin />
  <link rel="preload" as="font" type="font/woff2" href="/fonts/lato-400.woff2" crossorigin />

  <link rel="stylesheet" href="/styles.css" />
  <script>document.documentElement.classList.remove('no-js');document.documentElement.classList.add('js');</script>

  <!-- ===================== ESTILOS PROPIOS DE LA CARTA ===================== -->
  <style>
    /* La carta usa los tokens de styles.css (--terra, --cream, etc). No los redefinimos. */
    :root { --header-h: 72px; }

    /* En esta página el header es SÓLIDO crema desde arriba (no hay foto hero). */
    .site-header {
      background: rgba(243, 233, 214, .96);
      backdrop-filter: blur(14px) saturate(1.2);
      box-shadow: 0 1px 0 rgba(51, 51, 51, .08);
    }
    .site-header.scrolled {
      box-shadow: 0 1px 0 rgba(51, 51, 51, .08), 0 10px 30px -24px rgba(51, 51, 51, .5);
    }
    /* Afordancia "volver al inicio" en el header */
    .header__back {
      display: inline-flex; align-items: center; gap: .4rem;
      font-size: .9rem; font-weight: 500; color: var(--ink-soft);
      transition: color .2s var(--ease);
    }
    .header__back:hover { color: var(--terra-deep); }
    .header__back svg { transition: transform .2s var(--ease); }
    .header__back:hover svg { transform: translateX(-3px); }
    .nav__list a[aria-current="page"] { color: var(--ink); }
    .nav__list a[aria-current="page"]::after { transform: scaleX(1); }

    /* ---------- Banda intro ---------- */
    .menu-intro {
      background:
        radial-gradient(110% 90% at 88% 0%, rgba(212, 123, 59, .12), transparent 55%),
        radial-gradient(90% 80% at 0% 100%, rgba(212, 123, 59, .1), transparent 50%),
        var(--cream);
      padding-block: clamp(2.6rem, 6vw, 4.5rem) clamp(2rem, 4vw, 3rem);
      text-align: center;
    }
    .menu-intro__inner { max-width: 720px; margin-inline: auto; }
    .menu-intro__title {
      font-family: var(--font-display);
      font-weight: 600;
      font-optical-sizing: auto;
      font-size: clamp(2.4rem, 6vw, 4rem);
      line-height: 1.02;
      letter-spacing: -.025em;
      color: var(--ink);
      margin-top: .4rem;
      text-wrap: balance;
    }
    .menu-intro__title .ital { color: var(--terra); }
    .menu-intro__sub {
      margin-top: 1.1rem;
      font-size: clamp(1.02rem, 2.2vw, 1.18rem);
      color: var(--ink-soft);
      max-width: 50ch;
      margin-inline: auto;
      text-wrap: pretty;
    }
    .menu-intro__sub strong { color: var(--ink); font-weight: 600; }
    .menu-intro__dateline {
      margin-top: 1.4rem;
      font-family: var(--font-display);
      font-style: italic;
      font-size: .98rem;
      color: var(--terra-deep);
    }
    .menu-intro__disclaimer {
      margin-top: .55rem;
      font-size: .86rem;
      color: var(--ink-soft);
      max-width: 56ch;
      margin-inline: auto;
    }
    .menu-intro__actions {
      margin-top: 1.7rem;
      display: flex; flex-wrap: wrap; gap: .8rem; justify-content: center;
    }

    /* ---------- Tab bar pegajosa ---------- */
    .menu-tabs {
      position: sticky;
      top: var(--header-h, 72px);
      z-index: 80;
      background: rgba(243, 233, 214, .95);
      backdrop-filter: blur(12px) saturate(1.2);
      border-block: 1px solid rgba(51, 51, 51, .1);
    }
    .menu-tabs__scroll {
      display: flex;
      gap: .55rem;
      max-width: var(--maxw);
      margin-inline: auto;
      padding: .7rem var(--gutter);
      overflow-x: auto;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .menu-tabs__scroll::-webkit-scrollbar { display: none; }
    .menu-tab {
      scroll-snap-align: start;
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      font-size: .88rem;
      font-weight: 600;
      letter-spacing: .01em;
      color: var(--ink-soft);
      padding: .5rem 1rem;
      border: 1px solid rgba(51, 51, 51, .16);
      border-radius: 100px;
      background: var(--cream-card);
      white-space: nowrap;
      transition: background-color .2s var(--ease), color .2s var(--ease), border-color .2s var(--ease);
    }
    .menu-tab:hover { color: var(--terra-deep); border-color: rgba(175, 69, 46, .4); }
    .menu-tab.is-active {
      background: var(--terra-deep);
      color: #fff;
      border-color: var(--terra-deep);
    }
    .menu-tab:focus-visible {
      outline: 2px solid var(--terra);
      outline-offset: 2px;
    }

    /* ---------- Leyenda dietética ---------- */
    .menu-legend {
      background: var(--cream-200);
      border-bottom: 1px solid rgba(51, 51, 51, .08);
      padding-block: 1.1rem;
    }
    .menu-legend__inner {
      max-width: var(--maxw);
      margin-inline: auto;
      padding-inline: var(--gutter);
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: .7rem 1.1rem;
    }
    .menu-legend__note {
      flex-basis: 100%;
      display: flex;
      gap: .55rem;
      align-items: flex-start;
      margin: .6rem 0 0;
      padding: .7rem .95rem;
      background: rgba(175, 69, 46, .1);
      border: 1px solid rgba(175, 69, 46, .32);
      border-radius: 10px;
      font-size: .9rem;
      line-height: 1.5;
      color: var(--terra-deep);
      font-weight: 500;
    }
    .menu-legend__note-ic { font-size: 1.15rem; line-height: 1.1; flex: 0 0 auto; }
    .menu-legend__keys {
      display: flex; flex-wrap: wrap; gap: .5rem;
      list-style: none; padding: 0; margin: 0;
    }
    .menu-legend__keys li {
      display: inline-flex; align-items: center; gap: .35rem;
      font-size: .82rem; color: var(--ink-soft);
    }
    .menu-legend__price {
      margin-left: auto;
      font-size: .82rem; color: var(--ink-soft);
      font-variant-numeric: tabular-nums;
    }

    /* ---------- Pills dietéticas (con letra/ícono + color + aria-label) ---------- */
    .diet {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 1.55em;
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .02em;
      line-height: 1;
      padding: .26em .5em;
      border-radius: 6px;
      border: 1px solid currentColor;
      vertical-align: middle;
    }
    .diet--gf { color: #8a5a14; background: rgba(212, 123, 59, .16); }
    .diet--vg { color: #45511f; background: rgba(124, 132, 86, .26); }
    .diet--ve { color: #2c5329; background: rgba(76, 122, 64, .24); }
    .diet--spicy { color: var(--terra-deep); background: rgba(175, 69, 46, .12); border-color: rgba(175, 69, 46, .5); }
    .diet--house { color: #9c6a16; background: rgba(212, 123, 59, .14); border-color: rgba(212, 123, 59, .55); }

    /* ---------- Secciones de la carta ---------- */
    .menu-section {
      scroll-margin-top: calc(var(--header-h, 72px) + 64px);
      padding-block: clamp(3rem, 7vw, 5rem);
    }
    .menu-section:nth-of-type(even) { background: var(--cream-100); }
    .menu-section:nth-of-type(odd) { background: var(--cream); }
    .menu-section__head { margin-bottom: clamp(1.6rem, 3vw, 2.4rem); }
    .menu-section__title {
      font-family: var(--font-display);
      font-weight: 600;
      font-optical-sizing: auto;
      font-size: clamp(1.9rem, 4.5vw, 2.9rem);
      line-height: 1.05;
      letter-spacing: -.015em;
      color: var(--ink);
    }
    .menu-section__title .ital { color: var(--terra); font-style: italic; font-weight: 500; }
    .menu-section__sub {
      margin-top: .5rem;
      color: var(--ink-soft);
      font-size: 1.02rem;
      font-style: italic;
      font-family: var(--font-display);
    }

    /* Foto hero de sección */
    .menu-section__photo {
      margin: 0 0 clamp(1.6rem, 3vw, 2.4rem);
      border-radius: var(--radius);
      overflow: hidden;
      max-height: 320px;
      border: 1px solid rgba(51, 51, 51, .1);
      box-shadow: 0 28px 56px -38px rgba(51, 51, 51, .55);
    }
    .menu-section__photo img {
      width: 100%; height: 320px;
      object-fit: cover; display: block;
    }

    /* Filas de platos */
    .menu-items { list-style: none; padding: 0; margin: 0; }
    .menu-item {
      display: flex;
      align-items: flex-start;
      gap: 1.5rem;
      padding-block: clamp(1rem, 2.2vw, 1.35rem);
      border-bottom: 1px solid rgba(51, 51, 51, .1);
    }
    .menu-item:first-child { border-top: 1px solid rgba(51, 51, 51, .1); }
    .menu-item__thumb {
      flex: 0 0 clamp(64px, 18vw, 88px);
      width: clamp(64px, 18vw, 88px);
      height: clamp(64px, 18vw, 88px);
      border-radius: 14px;
      object-fit: cover;
      background: rgba(51, 51, 51, .06);
    }
    .menu-item--agotado .menu-item__thumb { filter: grayscale(.7); opacity: .6; }
    .menu-item__allerg {
      margin-top: .4rem;
      font-size: .76rem;
      letter-spacing: .02em;
      color: var(--ink-soft);
      opacity: .9;
    }
    .menu-item__allerg-ic { color: var(--terra); font-weight: 700; }
    .menu-section__extras {
      margin-top: 1.3rem;
      padding: .75rem 1rem;
      background: rgba(175, 69, 46, .07);
      border-left: 3px solid var(--terra);
      border-radius: 8px;
      font-size: .9rem;
      line-height: 1.55;
      color: var(--ink-soft);
    }
    .menu-item__main { flex: 1 1 auto; min-width: 0; }
    .menu-item__name {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 1.15rem;
      line-height: 1.25;
      color: var(--ink);
      display: flex; flex-wrap: wrap; align-items: center; gap: .45rem;
    }
    .menu-item__name .diet { margin-top: 1px; }
    .menu-item__desc {
      margin-top: .4rem;
      font-size: .92rem;
      color: var(--ink-soft);
      max-width: 60ch;
      text-wrap: pretty;
    }
    .menu-item__price {
      flex: 0 0 auto;
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 1.18rem;
      color: var(--terra-deep);
      font-variant-numeric: tabular-nums;
      padding-top: .1rem;
      text-align: right;
      min-width: 4ch;
    }

    /* Café: grid de 2 columnas más ligero */
    .menu-coffee {
      list-style: none; padding: 0; margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: .1rem 2.5rem;
    }
    .menu-coffee li {
      display: flex; align-items: baseline; gap: .75rem;
      padding-block: .7rem;
      border-bottom: 1px solid rgba(51, 51, 51, .08);
    }
    .menu-coffee__name {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: 1.02rem;
      color: var(--ink);
    }
    .menu-coffee__dots {
      flex: 1 1 auto;
      border-bottom: 1px dotted rgba(51, 51, 51, .22);
      transform: translateY(-.25em);
    }
    .menu-coffee__price {
      font-family: var(--font-display);
      font-weight: 600;
      color: var(--terra-deep);
      font-variant-numeric: tabular-nums;
    }
    .menu-note {
      margin-top: 1.2rem;
      font-size: .9rem;
      color: var(--ink-soft);
      font-style: italic;
    }
    .menu-note strong { color: var(--ink); font-style: normal; }

    /* Bebidas: grid de 2 columnas como café */
    .menu-drinks { list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(2, 1fr); gap: .1rem 2.5rem; }
    .menu-drinks li {
      display: flex; align-items: baseline; gap: .75rem;
      padding-block: .7rem;
      border-bottom: 1px solid rgba(51, 51, 51, .08);
    }
    .menu-drinks__name { font-family: var(--font-display); font-weight: 500; font-size: 1.02rem; color: var(--ink); }
    .menu-drinks__dots { flex: 1 1 auto; border-bottom: 1px dotted rgba(51, 51, 51, .22); transform: translateY(-.25em); }
    .menu-drinks__price { font-family: var(--font-display); font-weight: 600; color: var(--terra-deep); font-variant-numeric: tabular-nums; }

    /* Cierre / volver */
    .menu-outro {
      background: var(--espresso);
      color: var(--on-dark);
      text-align: center;
      padding-block: clamp(3rem, 7vw, 5rem);
    }
    .menu-outro__title {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: clamp(1.8rem, 4.5vw, 2.8rem);
      color: var(--cream-100);
      text-wrap: balance;
    }
    .menu-outro__title .ital { color: var(--gold); font-style: italic; }
    .menu-outro__actions { margin-top: 1.8rem; display: flex; flex-wrap: wrap; gap: .9rem; justify-content: center; }
    .menu-outro .btn--ghost { color: var(--cream-100); border-color: rgba(244, 234, 217, .3); }
    .menu-outro .btn--ghost:hover { color: var(--gold); border-color: var(--gold); background: rgba(212, 123, 59, .1); }

    /* ---------- Barra de acción móvil ---------- */
    .menu-actionbar {
      display: none;
      position: fixed;
      left: 0; right: 0; bottom: 0;
      z-index: 95;
      gap: .7rem;
      padding: .7rem var(--gutter) calc(.7rem + env(safe-area-inset-bottom));
      background: rgba(243, 233, 214, .97);
      backdrop-filter: blur(14px) saturate(1.2);
      border-top: 1px solid rgba(51, 51, 51, .12);
      box-shadow: 0 -10px 30px -24px rgba(51, 51, 51, .6);
    }
    .menu-actionbar .btn { flex: 1 1 0; min-height: 48px; }

    @media (max-width: 900px) {
      .menu-actionbar { display: flex; }
      .menu-coffee, .menu-drinks { grid-template-columns: 1fr; }
      /* dejar aire para que la barra no tape el footer */
      .site-footer { padding-bottom: calc(2rem + 64px); }
      .menu-section__photo img { height: 240px; }
    }
    @media (max-width: 540px) {
      .menu-legend__price { margin-left: 0; }
      .menu-item { gap: 1rem; }
      .menu-section__photo img { height: 200px; }
    }

    /* ---------- Reveal opcional (respeta reduced-motion via styles.css) ---------- */
    .js .menu-section .reveal { /* hereda de styles.css */ }

    /* ---------- Print: carta limpia para el personal ---------- */
    @media print {
      .site-header, .menu-tabs, .menu-legend, .menu-actionbar,
      .wa-float, .site-footer, .menu-intro__actions, .menu-outro,
      .menu-section__photo { display: none !important; }
      html, body { background: #fff !important; color: #000 !important; }
      .menu-intro { background: #fff !important; padding-block: 1rem 0; text-align: left; }
      .menu-intro__title { color: #000 !important; font-size: 1.8rem; }
      .menu-intro__title .ital { color: #000 !important; }
      .menu-section { background: #fff !important; padding-block: .8rem; break-inside: avoid; }
      .menu-section__title, .menu-item__name, .menu-coffee__name, .menu-drinks__name { color: #000 !important; }
      .menu-item__price, .menu-coffee__price, .menu-drinks__price { color: #000 !important; }
      .menu-item__desc, .menu-section__sub { color: #333 !important; }
      .menu-coffee, .menu-drinks { grid-template-columns: 1fr 1fr; }
      .diet { border-color: #000 !important; color: #000 !important; background: none !important; }
      a[href]::after { content: ""; }
    }
  </style>
</head>
<body>
  <a class="skip-link" href="#contenido">{{ ui.a11y.skipToContent }}</a>

  <!-- ===================== HEADER ===================== -->
  <header class="site-header" id="top">
    <div class="container header__inner">
      <a class="brand" href="index.html" aria-label="{{ ui.a11y.brandHomeLabel }}">
        <span class="brand__mark" aria-hidden="true">
          {% include "logo-mark.njk" %}
        </span>
        <span class="brand__word" translate="no">{% include "arau-word.njk" %}</span>
      </a>

      <nav class="nav" aria-label="{{ ui.a11y.navLabel }}">
        <ul class="nav__list" id="primary-nav">
          <li><a href="index.html">{{ ui.carta.nav.inicio }}</a></li>
          <li><a href="#top" aria-current="page">{{ ui.carta.nav.carta }}</a></li>
          <li><a href="index.html#cafe">{{ ui.carta.nav.cafe }}</a></li>
          <li><a href="index.html#visitanos">{{ ui.carta.nav.visitanos }}</a></li>
        </ul>
      </nav>

      <div class="header__actions">
        {% include "lang-switcher.njk" %}
        <a class="header__back" href="index.html">
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M19 12H5M11 6l-6 6 6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {{ ui.carta.header.backInicio }}
        </a>
        <a class="btn btn--terra" href="index.html#reservar">{{ ui.cta.reservar }}</a>
        <button class="nav-toggle" type="button" aria-label="{{ ui.a11y.openMenu }}" aria-expanded="false" aria-controls="primary-nav">
          <span class="nav-toggle__bar" aria-hidden="true"></span>
          <span class="nav-toggle__bar" aria-hidden="true"></span>
          <span class="nav-toggle__bar" aria-hidden="true"></span>
        </button>
      </div>
    </div>
  </header>

  <main id="contenido">

    <!-- ===================== INTRO ===================== -->
    <section class="menu-intro" aria-labelledby="menu-title">
      <div class="container menu-intro__inner">
        <p class="section-eyebrow">{{ carta.intro.eyebrow }}</p>
        <h1 class="menu-intro__title" id="menu-title">{{ carta.intro.titleStart }} <span class="ital" translate="no">{% include "arau-word.njk" %}</span></h1>
        <p class="menu-intro__sub">{{ carta.intro.subtitle }}</p>
        <p class="menu-intro__dateline">{{ carta.intro.dateline }}</p>
        <p class="menu-intro__disclaimer">{{ carta.intro.disclaimer }}</p>
        <div class="menu-intro__actions">
          <a class="btn btn--ghost" href="https://instagram.com/araubrunch" target="_blank" rel="noopener noreferrer">
            {{ ui.carta.intro.actionInstagram }}
            <svg class="btn__arrow" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ===================== TABS PEGAJOSAS ===================== -->
