  <!-- Scroll-spy de la carta (mejora progresiva; sin librerías) -->
  <script>
    (function () {
      'use strict';
      var tabs = Array.prototype.slice.call(document.querySelectorAll('.menu-tab'));
      if (!tabs.length || !('IntersectionObserver' in window)) return;

      var byId = {};
      tabs.forEach(function (t) { byId[t.getAttribute('data-tab')] = t; });

      function setActive(id) {
        tabs.forEach(function (t) {
          var on = t.getAttribute('data-tab') === id;
          t.classList.toggle('is-active', on);
          if (on) { t.setAttribute('aria-current', 'true'); }
          else { t.removeAttribute('aria-current'); }
        });
        // mantener visible la pill activa en la barra scrolleable
        var active = byId[id];
        if (active && active.scrollIntoView) {
          try { active.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' }); } catch (e) {}
        }
      }

      var sections = tabs
        .map(function (t) { return document.getElementById(t.getAttribute('data-tab')); })
        .filter(Boolean);

      // rootMargin afinado: la sección que queda justo bajo la barra "gana".
      var io = new IntersectionObserver(function (entries) {
        // elegir la entrada visible más cercana al tope
        var best = null;
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            if (!best || e.boundingClientRect.top < best.boundingClientRect.top) best = e;
          }
        });
        if (best && best.target.id) setActive(best.target.id);
      }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });

      sections.forEach(function (s) { io.observe(s); });

      // estado inicial
      if (sections.length) setActive(sections[0].id);
    })();
  </script>

  <!-- Pedido en la mesa: se activa con ?mesa=N o ?pedir (sin librerías) -->
  <script>
    (function () {
      'use strict';
      var bar = document.getElementById('order-bar');
      if (!bar) return;
      var params = new URLSearchParams(location.search);
      var mesa = params.get('mesa');
      if (mesa === null && !params.has('pedir')) return;

      var wa = bar.getAttribute('data-wa');
      var countEl = document.getElementById('order-count');
      var totalEl = document.getElementById('order-total');
      var dlg = document.getElementById('order-dialog');
      var listEl = document.getElementById('order-list');
      var emptyEl = document.getElementById('order-empty');
      var dtotalEl = document.getElementById('order-dtotal');
      var sendEl = document.getElementById('order-send');
      var cart = {};

      function esc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;'); }
      function price(s) { return parseFloat(String(s).replace(/[^0-9,.-]/g, '').replace(',', '.')) || 0; }
      function fmt(n) { return '€' + n.toFixed(2).replace('.', ','); }
      function totals() { var c = 0, t = 0; Object.keys(cart).forEach(function (k) { c += cart[k].qty; t += cart[k].qty * cart[k].precio; }); return { count: c, total: t }; }

      function render() {
        var tt = totals();
        countEl.textContent = tt.count;
        totalEl.textContent = fmt(tt.total);
        dtotalEl.textContent = fmt(tt.total);
        bar.classList.toggle('has-items', tt.count > 0);
        var keys = Object.keys(cart);
        emptyEl.hidden = keys.length > 0;
        listEl.innerHTML = keys.map(function (k) {
          var it = cart[k];
          return '<li class="order-line"><span class="order-line__name">' + esc(it.nombre) + '</span>' +
            '<span class="order-line__qty"><button type="button" class="order-qty" data-k="' + esc(k) + '" data-d="-1" aria-label="Quitar uno de ' + esc(it.nombre) + '">−</button>' +
            '<b>' + it.qty + '</b>' +
            '<button type="button" class="order-qty" data-k="' + esc(k) + '" data-d="1" aria-label="Agregar uno de ' + esc(it.nombre) + '">+</button></span>' +
            '<span class="order-line__price">' + fmt(it.qty * it.precio) + '</span></li>';
        }).join('');
      }
      function change(nombre, precio, d) {
        if (!cart[nombre]) cart[nombre] = { nombre: nombre, precio: precio, qty: 0 };
        cart[nombre].qty += d;
        if (cart[nombre].qty <= 0) delete cart[nombre];
        render();
      }

      var sel = '.menu-item[data-precio]:not([data-agotado]), .menu-coffee li[data-precio]:not([data-agotado]), .menu-drinks li[data-precio]:not([data-agotado])';
      Array.prototype.forEach.call(document.querySelectorAll(sel), function (li) {
        var nombre = li.getAttribute('data-nombre');
        var precio = price(li.getAttribute('data-precio'));
        var b = document.createElement('button');
        b.type = 'button'; b.className = 'add-btn'; b.setAttribute('aria-label', 'Agregar ' + nombre);
        b.innerHTML = '<span aria-hidden="true">+</span> Agregar';
        b.addEventListener('click', function () { change(nombre, precio, 1); b.classList.add('is-added'); setTimeout(function () { b.classList.remove('is-added'); }, 550); });
        li.appendChild(b);
      });

      if (mesa) document.getElementById('order-mesa').textContent = '· Mesa ' + mesa;
      bar.hidden = false;
      document.body.classList.add('has-order-bar');

      document.getElementById('order-open').addEventListener('click', function () { if (dlg.showModal) dlg.showModal(); });
      document.getElementById('order-close').addEventListener('click', function () { dlg.close(); });
      dlg.addEventListener('click', function (e) { if (e.target === dlg) dlg.close(); });
      listEl.addEventListener('click', function (e) {
        var q = e.target.closest('.order-qty'); if (!q) return;
        var k = q.getAttribute('data-k');
        if (cart[k]) change(k, cart[k].precio, parseInt(q.getAttribute('data-d'), 10));
      });

      sendEl.addEventListener('click', function (e) {
        e.preventDefault();
        var tt = totals();
        if (tt.count === 0) { if (dlg.showModal && !dlg.open) dlg.showModal(); return; }
        var lines = Object.keys(cart).map(function (k) { return '• ' + cart[k].qty + 'x ' + cart[k].nombre; });
        var msg = '¡Hola ARAU! ' + (mesa ? ('Mesa ' + mesa + '. ') : '') + 'Quiero pedir:\n' + lines.join('\n') + '\n\nTotal aprox: ' + fmt(tt.total) + '\n¡Gracias!';
        window.open('https://wa.me/' + wa + '?text=' + encodeURIComponent(msg), '_blank', 'noopener');
      });
      document.getElementById('order-call').addEventListener('click', function () {
        var msg = (mesa ? ('Mesa ' + mesa + ': ') : '') + '¿Pueden acercarse a la mesa, por favor? 🙋';
        window.open('https://wa.me/' + wa + '?text=' + encodeURIComponent(msg), '_blank', 'noopener');
      });

      render();
    })();
  </script>
