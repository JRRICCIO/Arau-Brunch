  <!-- ===================== ESTILOS PROPIOS DE LA CARTA ===================== -->
  <style>
    /* La carta usa los tokens de styles.css (--terra, --cream, etc). No los redefinimos. */
    :root { --header-h: 72px; }

    /* En esta página el header es SÓLIDO crema desde arriba (no hay foto hero). */
    .site-header {
      background: rgba(243, 233, 214, .96);
      backdrop-filter: blur(14px) saturate(1.2);
      box-shadow: 0 1px 0 rgba(52, 37, 28, .08);
    }
    .site-header.scrolled {
      box-shadow: 0 1px 0 rgba(52, 37, 28, .08), 0 10px 30px -24px rgba(52, 37, 28, .5);
    }
    /* Afordancia "volver al inicio" en el header */
    .header__back {
      display: inline-flex; align-items: center; gap: .4rem;
      font-size: .9rem; font-weight: 500; color: var(--ink-soft);
      transition: color .2s var(--ease);
    }
    .header__back:hover { color: var(--terra-deep); }
    .header__back svg { transition: transform .2s var(--ease); }
    .header__back:hover svg { transform: translateX(-3px); }
    .nav__list a[aria-current="page"] { color: var(--ink); }
    .nav__list a[aria-current="page"]::after { transform: scaleX(1); }

    /* ---------- Banda intro ---------- */
    .menu-intro {
      background:
        radial-gradient(110% 90% at 88% 0%, rgba(217, 99, 58, .12), transparent 55%),
        radial-gradient(90% 80% at 0% 100%, rgba(217, 154, 62, .1), transparent 50%),
        var(--cream);
      padding-block: clamp(2.6rem, 6vw, 4.5rem) clamp(2rem, 4vw, 3rem);
      text-align: center;
    }
    .menu-intro__inner { max-width: 720px; margin-inline: auto; }
    .menu-intro__title {
      font-family: var(--font-display);
      font-weight: 600;
      font-optical-sizing: auto;
      font-size: clamp(2.4rem, 6vw, 4rem);
      line-height: 1.02;
      letter-spacing: -.025em;
      color: var(--ink);
      margin-top: .4rem;
      text-wrap: balance;
    }
    .menu-intro__title .ital { color: var(--terra); }
    .menu-intro__sub {
      margin-top: 1.1rem;
      font-size: clamp(1.02rem, 2.2vw, 1.18rem);
      color: var(--ink-soft);
      max-width: 50ch;
      margin-inline: auto;
      text-wrap: pretty;
    }
    .menu-intro__sub strong { color: var(--ink); font-weight: 600; }
    .menu-intro__dateline {
      margin-top: 1.4rem;
      font-family: var(--font-display);
      font-style: italic;
      font-size: .98rem;
      color: var(--terra-deep);
    }
    .menu-intro__disclaimer {
      margin-top: .55rem;
      font-size: .86rem;
      color: var(--ink-soft);
      max-width: 56ch;
      margin-inline: auto;
    }
    .menu-intro__actions {
      margin-top: 1.7rem;
      display: flex; flex-wrap: wrap; gap: .8rem; justify-content: center;
    }

    /* ---------- Tab bar pegajosa ---------- */
    .menu-tabs {
      position: sticky;
      top: var(--header-h, 72px);
      z-index: 80;
      background: rgba(243, 233, 214, .95);
      backdrop-filter: blur(12px) saturate(1.2);
      border-block: 1px solid rgba(52, 37, 28, .1);
    }
    .menu-tabs__scroll {
      display: flex;
      gap: .55rem;
      max-width: var(--maxw);
      margin-inline: auto;
      padding: .7rem var(--gutter);
      overflow-x: auto;
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .menu-tabs__scroll::-webkit-scrollbar { display: none; }
    .menu-tab {
      scroll-snap-align: start;
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      font-size: .88rem;
      font-weight: 600;
      letter-spacing: .01em;
      color: var(--ink-soft);
      padding: .5rem 1rem;
      border: 1px solid rgba(52, 37, 28, .16);
      border-radius: 100px;
      background: var(--cream-card);
      white-space: nowrap;
      transition: background-color .2s var(--ease), color .2s var(--ease), border-color .2s var(--ease);
    }
    .menu-tab:hover { color: var(--terra-deep); border-color: rgba(189, 75, 43, .4); }
    .menu-tab.is-active {
      background: var(--terra-deep);
      color: #fff;
      border-color: var(--terra-deep);
    }
    .menu-tab:focus-visible {
      outline: 2px solid var(--terra);
      outline-offset: 2px;
    }

    /* ---------- Leyenda dietética ---------- */
    .menu-legend {
      background: var(--cream-200);
      border-bottom: 1px solid rgba(52, 37, 28, .08);
      padding-block: 1.1rem;
    }
    .menu-legend__inner {
      max-width: var(--maxw);
      margin-inline: auto;
      padding-inline: var(--gutter);
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: .7rem 1.1rem;
    }
    .menu-legend__lead {
      font-size: .9rem;
      color: var(--ink);
      font-weight: 500;
    }
    .menu-legend__lead strong { color: var(--terra-deep); font-weight: 700; }
    .menu-legend__keys {
      display: flex; flex-wrap: wrap; gap: .5rem;
      list-style: none; padding: 0; margin: 0;
    }
    .menu-legend__keys li {
      display: inline-flex; align-items: center; gap: .35rem;
      font-size: .82rem; color: var(--ink-soft);
    }
    .menu-legend__price {
      margin-left: auto;
      font-size: .82rem; color: var(--ink-soft);
      font-variant-numeric: tabular-nums;
    }

    /* ---------- Pills dietéticas (con letra/ícono + color + aria-label) ---------- */
    .diet {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 1.55em;
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .02em;
      line-height: 1;
      padding: .26em .5em;
      border-radius: 6px;
      border: 1px solid currentColor;
      vertical-align: middle;
    }
    .diet--gf { color: #8a5a14; background: rgba(217, 154, 62, .16); }
    .diet--vg { color: #45511f; background: rgba(124, 132, 86, .26); }
    .diet--ve { color: #2c5329; background: rgba(76, 122, 64, .24); }
    .diet--spicy { color: var(--terra-deep); background: rgba(189, 75, 43, .12); border-color: rgba(189, 75, 43, .5); }
    .diet--house { color: #9c6a16; background: rgba(217, 154, 62, .14); border-color: rgba(217, 154, 62, .55); }

    /* ---------- Secciones de la carta ---------- */
    .menu-section {
      scroll-margin-top: calc(var(--header-h, 72px) + 64px);
      padding-block: clamp(3rem, 7vw, 5rem);
    }
    .menu-section:nth-of-type(even) { background: var(--cream-100); }
    .menu-section:nth-of-type(odd) { background: var(--cream); }
    .menu-section__head { margin-bottom: clamp(1.6rem, 3vw, 2.4rem); }
    .menu-section__title {
      font-family: var(--font-display);
      font-weight: 600;
      font-optical-sizing: auto;
      font-size: clamp(1.9rem, 4.5vw, 2.9rem);
      line-height: 1.05;
      letter-spacing: -.015em;
      color: var(--ink);
    }
    .menu-section__title .ital { color: var(--terra); font-style: italic; font-weight: 500; }
    .menu-section__sub {
      margin-top: .5rem;
      color: var(--ink-soft);
      font-size: 1.02rem;
      font-style: italic;
      font-family: var(--font-display);
    }

    /* Foto hero de sección */
    .menu-section__photo {
      margin: 0 0 clamp(1.6rem, 3vw, 2.4rem);
      border-radius: var(--radius);
      overflow: hidden;
      max-height: 320px;
      border: 1px solid rgba(52, 37, 28, .1);
      box-shadow: 0 28px 56px -38px rgba(52, 37, 28, .55);
    }
    .menu-section__photo img {
      width: 100%; height: 320px;
      object-fit: cover; display: block;
    }

    /* Filas de platos */
    .menu-items { list-style: none; padding: 0; margin: 0; }
    .menu-item {
      display: flex;
      align-items: flex-start;
      gap: 1.5rem;
      padding-block: clamp(1rem, 2.2vw, 1.35rem);
      border-bottom: 1px solid rgba(52, 37, 28, .1);
    }
    .menu-item:first-child { border-top: 1px solid rgba(52, 37, 28, .1); }
    .menu-item__main { flex: 1 1 auto; min-width: 0; }
    .menu-item__name {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 1.15rem;
      line-height: 1.25;
      color: var(--ink);
      display: flex; flex-wrap: wrap; align-items: center; gap: .45rem;
    }
    .menu-item__name .diet { margin-top: 1px; }
    .menu-item__desc {
      margin-top: .4rem;
      font-size: .92rem;
      color: var(--ink-soft);
      max-width: 60ch;
      text-wrap: pretty;
    }
    .menu-item__price {
      flex: 0 0 auto;
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 1.18rem;
      color: var(--terra-deep);
      font-variant-numeric: tabular-nums;
      padding-top: .1rem;
      text-align: right;
      min-width: 4ch;
    }

    /* Café: grid de 2 columnas más ligero */
    .menu-coffee {
      list-style: none; padding: 0; margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: .1rem 2.5rem;
    }
    .menu-coffee li {
      display: flex; align-items: baseline; gap: .75rem;
      padding-block: .7rem;
      border-bottom: 1px solid rgba(52, 37, 28, .08);
    }
    .menu-coffee__name {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: 1.02rem;
      color: var(--ink);
    }
    .menu-coffee__dots {
      flex: 1 1 auto;
      border-bottom: 1px dotted rgba(52, 37, 28, .22);
      transform: translateY(-.25em);
    }
    .menu-coffee__price {
      font-family: var(--font-display);
      font-weight: 600;
      color: var(--terra-deep);
      font-variant-numeric: tabular-nums;
    }
    .menu-note {
      margin-top: 1.2rem;
      font-size: .9rem;
      color: var(--ink-soft);
      font-style: italic;
    }
    .menu-note strong { color: var(--ink); font-style: normal; }

    /* Bebidas: grid de 2 columnas como café */
    .menu-drinks { list-style: none; padding: 0; margin: 0;
      display: grid; grid-template-columns: repeat(2, 1fr); gap: .1rem 2.5rem; }
    .menu-drinks li {
      display: flex; align-items: baseline; gap: .75rem;
      padding-block: .7rem;
      border-bottom: 1px solid rgba(52, 37, 28, .08);
    }
    .menu-drinks__name { font-family: var(--font-display); font-weight: 500; font-size: 1.02rem; color: var(--ink); }
    .menu-drinks__dots { flex: 1 1 auto; border-bottom: 1px dotted rgba(52, 37, 28, .22); transform: translateY(-.25em); }
    .menu-drinks__price { font-family: var(--font-display); font-weight: 600; color: var(--terra-deep); font-variant-numeric: tabular-nums; }

    /* Cierre / volver */
    .menu-outro {
      background: var(--espresso);
      color: var(--on-dark);
      text-align: center;
      padding-block: clamp(3rem, 7vw, 5rem);
    }
    .menu-outro__title {
      font-family: var(--font-display);
      font-weight: 500;
      font-size: clamp(1.8rem, 4.5vw, 2.8rem);
      color: var(--cream-100);
      text-wrap: balance;
    }
    .menu-outro__title .ital { color: var(--gold); font-style: italic; }
    .menu-outro__actions { margin-top: 1.8rem; display: flex; flex-wrap: wrap; gap: .9rem; justify-content: center; }
    .menu-outro .btn--ghost { color: var(--cream-100); border-color: rgba(244, 234, 217, .3); }
    .menu-outro .btn--ghost:hover { color: var(--gold); border-color: var(--gold); background: rgba(217, 154, 62, .1); }

    /* ---------- Barra de acción móvil ---------- */
    .menu-actionbar {
      display: none;
      position: fixed;
      left: 0; right: 0; bottom: 0;
      z-index: 95;
      gap: .7rem;
      padding: .7rem var(--gutter) calc(.7rem + env(safe-area-inset-bottom));
      background: rgba(243, 233, 214, .97);
      backdrop-filter: blur(14px) saturate(1.2);
      border-top: 1px solid rgba(52, 37, 28, .12);
      box-shadow: 0 -10px 30px -24px rgba(52, 37, 28, .6);
    }
    .menu-actionbar .btn { flex: 1 1 0; min-height: 48px; }

    @media (max-width: 900px) {
      .menu-actionbar { display: flex; }
      .menu-coffee, .menu-drinks { grid-template-columns: 1fr; }
      /* dejar aire para que la barra no tape el footer */
      .site-footer { padding-bottom: calc(2rem + 64px); }
      .menu-section__photo img { height: 240px; }
    }
    @media (max-width: 540px) {
      .menu-legend__price { margin-left: 0; }
      .menu-item { gap: 1rem; }
      .menu-section__photo img { height: 200px; }
    }

    /* ---------- Reveal opcional (respeta reduced-motion via styles.css) ---------- */
    .js .menu-section .reveal { /* hereda de styles.css */ }

    /* ---------- Print: carta limpia para el personal ---------- */
    @media print {
      .site-header, .menu-tabs, .menu-legend, .menu-actionbar,
      .wa-float, .site-footer, .menu-intro__actions, .menu-outro,
      .menu-section__photo { display: none !important; }
      html, body { background: #fff !important; color: #000 !important; }
      .menu-intro { background: #fff !important; padding-block: 1rem 0; text-align: left; }
      .menu-intro__title { color: #000 !important; font-size: 1.8rem; }
      .menu-intro__title .ital { color: #000 !important; }
      .menu-section { background: #fff !important; padding-block: .8rem; break-inside: avoid; }
      .menu-section__title, .menu-item__name, .menu-coffee__name, .menu-drinks__name { color: #000 !important; }
      .menu-item__price, .menu-coffee__price, .menu-drinks__price { color: #000 !important; }
      .menu-item__desc, .menu-section__sub { color: #333 !important; }
      .menu-coffee, .menu-drinks { grid-template-columns: 1fr 1fr; }
      .diet { border-color: #000 !important; color: #000 !important; background: none !important; }
      a[href]::after { content: ""; }
    }
  </style>
</head>
<body>
  <a class="skip-link" href="#contenido">Saltar al contenido</a>

  <!-- ===================== HEADER ===================== -->
  <header class="site-header" id="top">
    <div class="container header__inner">
      <a class="brand" href="index.html" aria-label="ARAU · Inicio">
        <span class="brand__mark" aria-hidden="true">
          <svg viewBox="0 0 100 104" width="36" height="37" role="img" aria-label="ARAU">
            <g fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <!-- vapor -->
              <path d="M43 20c-3-3-3-6 0-9"/>
              <path d="M50 18c-3-3-3-6 0-9"/>
              <path d="M57 20c-3-3-3-6 0-9"/>
              <!-- borde taza -->
              <ellipse cx="50" cy="30" rx="17" ry="4.6"/>
              <!-- cuerpo taza -->
              <path d="M33 30c0 16 2 28 4 37a4 4 0 0 0 4 3h18a4 4 0 0 0 4-3c2-9 4-21 4-37"/>
              <!-- línea del café -->
              <path d="M35.5 39c6 2 23 2 29 0"/>
              <!-- sonrisa -->
              <path d="M44 60c4 3.5 8 3.5 12 0"/>
              <!-- brazo izq + cuchillo -->
              <path d="M33 47c-5 1-10-1-13-6"/>
              <path d="M20 41l-3-19"/>
              <!-- brazo der + tenedor -->
              <path d="M67 47c5 1 10-1 13-6"/>
              <path d="M80 41l3-19"/>
              <path d="M80.4 26l-.5-5M83 26l.4-5"/>
              <!-- piernas -->
              <path d="M44 70l-2 13M42 83l-6 2"/>
              <path d="M56 70l2 13M58 83l6 2"/>
            </g>
            <!-- punta cuchillo -->
            <path d="M17 22l-2.6 4.5 5.4 0z" fill="currentColor"/>
            <!-- anteojos de sol -->
            <g fill="currentColor">
              <rect x="37.5" y="45" width="10.5" height="7.4" rx="3.4"/>
              <rect x="52" y="45" width="10.5" height="7.4" rx="3.4"/>
              <rect x="47" y="47" width="6" height="2.2" rx="1"/>
            </g>
          </svg>
        </span>
        <span class="brand__word" translate="no">ARAU</span>
      </a>

      <nav class="nav" aria-label="Navegación principal">
        <ul class="nav__list" id="primary-nav">
          <li><a href="index.html">Inicio</a></li>
          <li><a href="#top" aria-current="page">Carta</a></li>
          <li><a href="index.html#cafe">Café</a></li>
          <li><a href="index.html#visitanos">Visitanos</a></li>
        </ul>
      </nav>

      <div class="header__actions">
        {% include "lang-switcher.njk" %}
        <a class="header__back" href="index.html">
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path d="M19 12H5M11 6l-6 6 6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Inicio
        </a>
        <a class="btn btn--terra" href="index.html#reservar">Reservar</a>
        <button class="nav-toggle" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="primary-nav">
          <span class="nav-toggle__bar" aria-hidden="true"></span>
          <span class="nav-toggle__bar" aria-hidden="true"></span>
          <span class="nav-toggle__bar" aria-hidden="true"></span>
        </button>
      </div>
    </div>
  </header>

  <main id="contenido">

    <!-- ===================== INTRO ===================== -->
    <section class="menu-intro" aria-labelledby="menu-title">
      <div class="container menu-intro__inner">
        <p class="section-eyebrow">La carta</p>
        <h1 class="menu-intro__title" id="menu-title">Comé como en <span class="ital" translate="no">ARAU</span></h1>
        <p class="menu-intro__sub">
          <strong>Aussie soul, Argentinian heart.</strong> Brunch a la brasa, huevos en su punto y café de
          especialidad — la carta completa, de principio a fin.
        </p>
        <p class="menu-intro__dateline">Carta de temporada · actualizada junio 2026</p>
        <p class="menu-intro__disclaimer">
          Los precios son orientativos y la carta puede variar según temporada y disponibilidad.
        </p>
        <div class="menu-intro__actions">
