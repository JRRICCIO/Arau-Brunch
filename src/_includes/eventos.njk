        <!-- Destacado: Bingo (con recuadro) -->
        <article class="event-feature event-feature--boxed reveal{% if not eventos.feature.photo %} event-feature--no-photo{% endif %}">
          {%- if eventos.feature.photo %}
          <div class="event-feature__media">
            <button type="button" class="event-feature__photo thumb" data-gallery="evento-feature"
                    data-full="{{ eventos.feature.photo | asset }}" data-caption="{{ eventos.feature.kicker }} — {{ eventos.feature.titleStart }} {{ eventos.feature.titleAccent }}">
              <img src="{{ eventos.feature.photo | asset }}" alt="{{ eventos.feature.photoAlt }}" width="760" height="560" loading="lazy" decoding="async" />
              <span class="event-feature__play" aria-hidden="true">{{ ui.eventos.feature.play }}</span>
            </button>
            <div class="event-strip" aria-label="Más fotos de {{ eventos.feature.kicker }}">
              {%- for s in eventos.feature.strip %}
              <button type="button" class="event-strip__thumb thumb" data-gallery="evento-feature" data-full="{{ s.src | asset }}" data-caption="{{ s.caption }}">
                <img src="{{ s.src | asset }}" alt="{{ s.alt }}" width="200" height="150" loading="lazy" decoding="async" />
              </button>
              {%- endfor %}
            </div>
          </div>
          {%- endif %}
          <div class="event-feature__body">
            <p class="event__kicker">{{ eventos.feature.kicker }}</p>
            <h3 class="event-feature__title">{{ eventos.feature.titleStart }} <span class="ital">{{ eventos.feature.titleAccent }}</span></h3>
            <span class="event__chip">{{ eventos.feature.chip }}</span>
            <p class="event-feature__desc">{{ eventos.feature.desc }}</p>
            <div class="event__actions">
              {%- if eventos.feature.inscripciones %}
              <button type="button" class="btn btn--terra js-inscribirme" data-evento-id="{{ eventos.feature.id }}" data-evento-nombre="{{ eventos.feature.kicker }}">{{ ui.inscripcion.cta }}</button>
              {%- endif %}
              <a class="inline-link" href="https://instagram.com/{{ site.contacto.instagram }}" target="_blank" rel="noopener noreferrer">{{ ui.eventos.feature.verFotosIg }}</a>
            </div>
          </div>
        </article>

        <!-- Otros eventos en Arau -->
        <div class="events-more reveal">
          <h3 class="events-more__title">{{ eventos.otros.heading }}</h3>
          <p class="events-more__sub">{{ eventos.otros.sub }}</p>
          <ul class="events-more__list">
            {%- for it in eventos.otros.items %}
            <li class="events-more__item">
              <h4 class="events-more__name">{{ it.title }}</h4>
              <p class="events-more__desc">{{ it.desc }}</p>
            </li>
            {%- endfor %}
          </ul>
          <button type="button" class="btn btn--terra js-inscribirme" data-evento-id="otros-eventos" data-evento-nombre="{{ eventos.otros.heading }}">{{ eventos.otros.cta }}</button>
        </div>
